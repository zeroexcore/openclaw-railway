{
  "update": {
    "channel": "stable"
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "reload": {
      "mode": "hot"
    },
    "auth": {
      "mode": "token"
    },
    "trustedProxies": ["127.0.0.1"],
    "controlUi": {
      "allowedOrigins": ["${ALLOWED_ORIGIN}"]
    }
  },
  "agents": {
    "defaults": {
      "model": "${OPENCLAW_MODEL:-opencode/minimax-m2.5-free}",
      "workspace": "/data/workspace"
    }
  }
}
